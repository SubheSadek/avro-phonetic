{
  "name": "@subhesadek/avro-phonetic",
  "version": "2.0.0",
  "description": "A TypeScript/JavaScript implementation of Avro Phonetic — convert English transliteration to Bangla (Bengali) Unicode text.",
  "keywords": [
    "avro",
    "avro-phonetic",
    "bangla",
    "bengali",
    "transliteration",
    "phonetic",
    "unicode",
    "bangladesh",
    "nlp",
    "i18n",
    "l10n"
  ],
  "homepage": "https://github.com/SubheSadek/avro-phonetic#readme",
  "bugs": {
    "url": "https://github.com/SubheSadek/avro-phonetic/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SubheSadek/avro-phonetic.git"
  },
  "license": "MPL-2.0",
  "author": "Sadek <subhesadek@gmail.com>",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "clean": "rimraf dist",
    "dev": "tsup --watch",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run test",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
