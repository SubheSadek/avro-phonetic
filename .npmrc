# .npmrc — avro-phonetic
#
# ── Registry ──────────────────────────────────────────────────
registry=https://registry.npmjs.org/

# ── Auth token ────────────────────────────────────────────────
# DO NOT commit a real token here.
#
# CI (GitHub Actions): `actions/setup-node` with `registry-url` writes the
# auth token line automatically from the NODE_AUTH_TOKEN env var.
#
# Local publishing:
#   export NPM_TOKEN=npm_xxxxxxxxxxxx
#   pnpm publish
